# Riptide Attest configuration.
#
# NOTHING here is required for the runtime verbs (snapshot, evaluate,
# replay, diff) or the demo: those are pure code. The API key is needed
# only for the authoring verbs (triage, compile, explain), which run once
# per control.

ANTHROPIC_API_KEY=

# Model routing policy: authoring-time only. All IDs are pinned snapshots;
# changing them is an operator decision per root CLAUDE.md, not a default.
# Opus sits at the compile step because that is Attest's trust boundary:
# a wrong spec produces wrong attestations forever.
MODEL_TRIAGE=claude-haiku-4-5-20251001
MODEL_COMPILER=claude-opus-4-8
MODEL_EXPLAINER=claude-haiku-4-5-20251001

# The human key for the one external side effect (publishing an attestation
# to the tracker). Read from the environment at the moment of the write;
# deliberately never stored in a configuration file. Set per run:
#   set ATTEST_PUBLISH_APPROVED=1     (Windows, current shell only)
# ATTEST_PUBLISH_APPROVED=

# Optional tracker integration for publish.
NOTION_API_KEY=
NOTION_DATABASE_ID=
